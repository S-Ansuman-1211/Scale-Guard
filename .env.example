# Resend settings used by /api/proposal to email info@scaleguard.in
# Set these in the Vercel project (Settings -> Environment Variables), not in the repo.

# API key from https://resend.com (Dashboard -> API Keys). Starts with "re_".
RESEND_API_KEY=re_your_api_key

# Sender address. Must be on a domain you've verified in Resend (e.g. proposals@scaleguard.in).
# If unset, the code uses Resend's shared test sender, which ONLY delivers to your own
# Resend account email - fine for a first test, not for production.
MAIL_FROM=proposals@scaleguard.in

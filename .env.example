# SMTP settings used by /api/proposal to email info@scaleguard.in
# Set these in the Vercel project (Settings → Environment Variables), not in the repo.

SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
# Optional. Defaults to SMTP_USER. Must be an address your SMTP provider lets you send from.
SMTP_FROM=info@scaleguard.in
